# Datenbank (lokal: Docker Compose, Produktion: PostgreSQL auf dem Server)
DATABASE_URL=postgresql://kima:changeme@localhost:5432/kimaflow

# Session-Secret (mind. 32 zufällige Zeichen)
SESSION_SECRET=bitte_aendern_min_32_zeichen_lang_abc123

# Docker Compose Passwörter (nur für docker-compose.yml)
DB_PASSWORD=changeme

# Dateispeicher (lokal: ./data/, Produktion: /app/data/)
STORAGE_DIR=./data/files

# Quellverzeichnis für den AB-Beleg-Import. {jahr} wird durch aktuelles
# Jahr + Vorjahr ersetzt. Produktion z. B.: /mnt/belege/{jahr}/Auftragsbestätigungen
BELEGE_DIR=./data/belege

# Automatischer Beleg-Import: Intervall in Sekunden (0 = aus, V2-Default 3600)
IMPORT_INTERVAL=3600

# Optional: zusätzlicher Foto-Export-Pfad
# FOTO_EXPORT_DIR=

# Abpackzeit in Minuten pro Stück für Lagerentnahmen (Soll-Zeit-Berechnung)
ABPACKZEIT_MINUTEN=2
